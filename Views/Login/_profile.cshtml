@{
	ViewData["Title"] = "Profile";
}

<div class="container-fluid py-4 px-3 px-md-5">
	<div class="d-flex align-items-center justify-content-between mb-4">
		<div class="fw-semibold fs-2 text-warning" style="text-shadow: 0 0 12px rgba(var(--bs-warning-rgb), .7);">ເກ(ມ)ປະ</div>

		<div class="w-100 mx-3 mx-md-5" style="max-width: 520px;">
			<div class="input-group input-group-lg">
				<span class="input-group-text bg-white border-end-0 rounded-start-pill">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
						<path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
					</svg>
				</span>
				<input type="search" class="form-control border-start-0 rounded-end-pill" placeholder="Search your game" />
			</div>
		</div>

		<div class="rounded-circle border border-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
				<circle cx="12" cy="8" r="4"></circle>
				<path d="M4 20c0-4.2 3.8-7 8-7s8 2.8 8 7"></path>
			</svg>
		</div>
	</div>

	<div class="text-center mt-4">
		<div class="rounded-circle bg-secondary mx-auto mb-2" style="width: 150px; height: 150px;"></div>
		<div class="text-white fw-semibold fs-4">Somchai Chira</div>
		<div class="text-white-50">somchaichira@gmail.com</div>
	</div>

	<hr class="my-4 text-secondary" />

	<div class="d-flex justify-content-center">
		<div class="text-center px-5 pb-2 border-bottom border-3 border-warning text-white">Profile</div>
	</div>
</div>
