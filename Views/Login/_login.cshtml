@{
	ViewData["Title"] = "Login";
}

<div class="bg-white rounded-4 p-3 p-md-4 mt-4">
	<div class="row g-0 align-items-stretch border rounded-4 overflow-hidden shadow-sm">
		<div class="col-lg-6 d-none d-lg-block">
			<div class="h-100 bg-secondary bg-gradient d-flex flex-column justify-content-between p-4 text-white">
				<div class="text-end">
					<a asp-controller="Home" asp-action="Index" class="btn btn-light btn-sm rounded-pill">Back to website</a>
				</div>
				<div>
					<h2 class="h4 mb-1">Welcome back</h2>
					<p class="mb-0">Add your image in this panel later to match your final brand style.</p>
				</div>
			</div>
		</div>

		<div class="col-12 col-lg-6 bg-white">
			<div class="p-4 p-md-5">
				<h1 class="display-6 fw-semibold text-dark mb-2">Sign in to your account</h1>
				<p class="text-secondary mb-4">
					Don't have an account?
					<a asp-controller="Login" asp-action="CreateAccount" class="fw-semibold text-decoration-none">Create one</a>
				</p>

				@if (TempData["LoginMessage"] is string message)
				{
					<div class="alert alert-success" role="alert">
						@message
					</div>
				}

				@if (!ViewData.ModelState.IsValid)
				{
					<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
				}

				<form asp-controller="Login" asp-action="Index" method="post">
					@Html.AntiForgeryToken()

					<div class="mb-3">
						<input id="email" name="email" type="email" class="form-control form-control-lg rounded-pill" placeholder="Email" required />
					</div>

					<div class="mb-3">
						<input id="password" name="password" type="password" class="form-control form-control-lg rounded-pill" placeholder="Enter your password" required />
					</div>

					<div class="d-flex justify-content-between align-items-center mb-4 small">
						<div class="form-check mb-0">
							<input id="rememberMe" name="rememberMe" type="checkbox" class="form-check-input" />
							<label class="form-check-label" for="rememberMe">Remember me</label>
						</div>
						<a href="#" class="text-decoration-none">Forgot password</a>
					</div>

					<button type="submit" class="btn btn-warning btn-lg w-100 rounded-pill">Sign in</button>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
