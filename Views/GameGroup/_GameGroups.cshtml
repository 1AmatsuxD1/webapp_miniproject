@model IEnumerable<GameInfo>

<div class="container-fluid p-0">
    <div div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 gx-2 gx-sm-3 gx-lg-4 gy-3 align-gameGroups-center masonry-grid">
        @foreach (var gameInfo in Model)
        {
            @foreach (var gameGroup in gameInfo.GameGroupInfos)
            {
                <div class="col">
                    <div class="card rounded-3 general-block">
                        <!-- Image -->
                        @if (!string.IsNullOrEmpty(gameGroup.ImageUrl))
                        {
                            <img src="@gameGroup.ImageUrl" class="card-img-top" alt="@gameGroup.Title" loading="lazy" />
                        }
                        <!-- Text -->
                        <div class="card-body d-flex flex-column">
                            <div class="mb-1 small text-muted">@gameInfo.Name</div>
                            <h5 class="card-title mb-3">
                                <a asp-controller="GameGroup" asp-action="Details" asp-route-id="@gameGroup.Id" class="text-decoration-none text-light">
                                    @gameGroup.Title
                                </a>
                            </h5>
                            <p class="card-text mb-3 text-light">@gameGroup.Description</p>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
