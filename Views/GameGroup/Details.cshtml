@model GameGroupInfo

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-10 col-md-4 mb-3">
            <div class="card rounded-3 general-block"">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" />
                }
                <div class="card-body d-flex flex-column">
                    <h1 class="h4 mb-3 text-light">@Model.Title</h1>
                    <p class="text-light">@Model.Description</p>
                </div>
            </div>
        </div>

        <div class="col d-flex flex-column">
            <div class="mb-3">
                <div class="card rounded-3 general-block">
                    <div class="w-full flex flex-row border-bottom p-2">
                        <button class="flex flex-col items-center btn">
                            <h4 class="text-light">Skills</h4>
                        </button>
                        <button class="flex flex-col items-center btn">
                            <h4 class="text-light">Moment</h4>
                        </button>
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <p>Test</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="card rounded-3 p-4 general-block">
                    <h4 class="text-light">User Review</h4>
                </div>
            </div>
        </div>
    </div>
</div>
